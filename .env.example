# ── Azure OpenAI (required) ──────────────────────────────────────────
# Authentication: Uses DefaultAzureCredential (az login, managed identity, etc.)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Azure AI Services + MAI models (required) ───────────────────────
# AIServices (multi-service) resource where MAI-Transcribe-1 + MAI-Voice-1 are deployed
AZURE_AI_SERVICES_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# Region of the AI Services resource (needed for TTS regional endpoint)
AZURE_SPEECH_REGION=eastus

# ── TTS voice + style (optional) ────────────────────────────────────
# MAI-Voice-1 voices:
#   en-US-Iris:MAI-Voice-1   (Female) - narration, neutral, excitement, happiness, hope, etc.
#   en-US-Grant:MAI-Voice-1  (Male)   - neutral, professional, determination, excitement, etc.
#   en-US-Jasper:MAI-Voice-1 (Male)   - media, persuasive, learning, sales, excitement, etc.
#   en-US-June:MAI-Voice-1   (Female) - customerservice, professional, learning, etc.
# Other voices: en-US-Ava:DragonHDLatestNeural, en-US-Andrew:DragonHDLatestNeural, etc.
TTS_VOICE=en-US-Iris:MAI-Voice-1
# Style (leave empty for default voice behavior)
# MAI-Voice-1 styles: narration, neutral, excitement, happiness, professional, generalconversation,
#   anger, confusion, determination, disgust, embarrassment, fear, hope, jealousy, joy,
#   regret, relief, sadness, shouting, softvoice, surprise, whispering
TTS_STYLE=narration
TARGET_DURATION_SECONDS=90

# ── Pipeline settings (optional) ────────────────────────────────────
MAX_CONCURRENT_TRANSCRIPTIONS=6
